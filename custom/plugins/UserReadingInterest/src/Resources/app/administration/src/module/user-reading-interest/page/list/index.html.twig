{% block user_reading_interest_list %}
    <sw-page class="user-reading-interest-list">
        <template #smart-bar-header>
            <h2>Reading Interests</h2>
        </template>

        <template #smart-bar-actions>
            <sw-button variant="secondary" @click="$router.push({ name: 'user.reading.interest.settings' })">
                Channel Settings
            </sw-button>
            <sw-button variant="secondary" :isLoading="isExporting" @click="onExportCsv">
                Export CSV
            </sw-button>
            <sw-button variant="primary" @click="onCreateNew">
                Add Interest
            </sw-button>
        </template>

        <template #content>
            <sw-card-view>
                <sw-card :isLoading="isLoading" class="user-reading-interest-list__card">
                    <div class="user-reading-interest-list__toolbar">
                        
                        <div class="user-reading-interest-list__controls">
                            <div class="user-reading-interest-list__filters">
                                <div class="user-reading-interest-list__field">
                                    <sw-text-field
                                        v-model:value="filterTerm"
                                        class="user-reading-interest-list__search"
                                        placeholder="Name, email, etc."
                                        label="Search"
                                        @keyup.enter="onApplyFilters" />
                                </div>

                                <div class="user-reading-interest-list__field">
                                    <sw-single-select
                                        v-model:value="selectedAttribute"
                                        class="user-reading-interest-list__attribute"
                                        label="Attribute"
                                        :options="attributeOptions"
                                        @update:value="onApplyFilters" />
                                </div>

                                <sw-button size="small" variant="tertiary" @click="onResetFilters">
                                    Reset
                                </sw-button>

                                <sw-context-button
                                    v-if="hasSelection"
                                    class="user-reading-interest-list__toolbar-bulk-action">
                                    <sw-context-menu-item variant="danger" @click="onBulkDeleteSelected">
                                        Delete selected
                                    </sw-context-menu-item>
                                </sw-context-button>
                            </div>

                            <div class="user-reading-interest-list__actions">
                            </div>
                        </div>
                    </div>

                    <sw-entity-listing
                        v-if="items"
                        ref="readingInterestListing"
                        :items="items"
                        :repository="repository"
                        :columns="columns"
                        :show-selection="true"
                        :allow-inline-edit="false"
                        :show-actions="false"
                        :allow-delete="false"
                        :sort-by="currentSortBy"
                        :sort-direction="sortDirection"
                        :natural-sorting="naturalSorting"
                        :full-page="false"
                        :isLoading="isLoading"
                        :total="total"
                        :page="page"
                        :limit="limit"
                        @page-change="onPageChange"
                        @column-sort="onColumnSort"
                        @selection-change="onSelectionChange"
                        @search-term-change="onSearch">
                        <template #column-customer.firstName="{ item }">
                            <div v-if="item.customer" class="user-reading-interest-list__customer">
                                <strong>{{ item.customer.firstName }} {{ item.customer.lastName }}</strong>
                                <span>{{ item.customer.email }}</span>
                            </div>
                            <span v-else>-</span>
                        </template>

                        <template #column-createdAt="{ item }">
                            <sw-time-ago v-if="item.createdAt" :date="item.createdAt" />
                            <span v-else>-</span>
                        </template>

                        <template #column-description="{ item }">
                            <span class="user-reading-interest-list__description-text" :title="item.description || ''">
                                {{ item.description || '-' }}
                            </span>
                        </template>

                        <template #column-rowActions="{ item }">
                            <sw-context-button class="user-reading-interest-list__row-action">
                                <sw-context-menu-item @click="onEdit(item)">
                                    Edit
                                </sw-context-menu-item>
                                <sw-context-menu-item variant="danger" @click="onDelete(item)">
                                    Delete
                                </sw-context-menu-item>
                            </sw-context-button>
                        </template>
                    </sw-entity-listing>
                </sw-card>
            </sw-card-view>
            <sw-modal
                v-if="showModal"
                :title="currentItem.id ? 'Edit Reading Interest' : 'Create Reading Interest'"
                @modal-close="onCloseModal">

                <sw-entity-single-select
                    v-model:value="currentItem.customerId"
                    entity="customer"
                    label="Customer"
                    placeholder="Select customer"
                    label-property="email"
                    :criteria="customerCriteria" />

                <sw-single-select
                    v-model:value="currentItem.name"
                    label="Interest Name"
                    :options="interestSelectOptions"
                    placeholder="Select interest"
                    required />

                <sw-textarea-field
                    v-model="currentItem.description"
                    label="Description"
                    placeholder="Optional" />

                <template #modal-footer>
                    <sw-button @click="onCloseModal">Cancel</sw-button>
                    <sw-button variant="primary" :isLoading="isSaving" @click="onSave">Save</sw-button>
                </template>
            </sw-modal>
        </template>
    </sw-page>
{% endblock %}
