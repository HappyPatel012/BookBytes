{% sw_extends '@Storefront/storefront/page/account/sidebar.html.twig' %}

{% block page_account_sidebar_menu_inner %}
    {{ parent() }}

    {% set allowedSalesChannels = config('UserReadingInterest.config.enabledSalesChannels') %}
    {% if allowedSalesChannels is iterable and context.salesChannel.id in allowedSalesChannels %}
        <a href="{{ path('frontend.account.reading_interest.page') }}"
           title="My Reading Interests"
           class="list-group-item list-group-item-action account-aside-item{% if activeRoute is same as('frontend.account.reading_interest.page') %} is-active{% endif %}"
           {% if activeRoute is same as('frontend.account.reading_interest.page') %} aria-current="page"{% endif %}>
            My Reading Interests
        </a>
    {% endif %}
{% endblock %}
