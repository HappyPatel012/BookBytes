{% block user_reading_interest_settings %}
    <sw-page class="user-reading-interest-settings">
        <template #smart-bar-header>
            <h2>Reading Interest Settings</h2>
        </template>

        <template #smart-bar-actions>
            <sw-button-process
                :is-loading="isSaving"
                variant="primary"
                @click="onSave">
                Save
            </sw-button-process>
        </template>

        <template #content>
            <sw-card-view>
                <sw-card title="Allowed Sales Channels" :isLoading="isLoading">
                    <p class="sw-field__help-text" style="margin-bottom: 12px;">
                        Select channels where Reading Interests are enabled. If empty, feature is disabled everywhere.
                    </p>

                    <sw-entity-multi-id-select
                        v-model:value="allowedSalesChannels"
                        entity="sales_channel"
                        label="Allowed sales channels"
                        placeholder="Select one or more sales channels" />
                </sw-card>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}
