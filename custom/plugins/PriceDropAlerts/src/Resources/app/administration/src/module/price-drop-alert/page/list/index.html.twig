{% block price_drop_alert_list %}
    <sw-page class="price-drop-alert-list">
        <template #smart-bar-header>
            <h2>Price Drop Alerts</h2>
        </template>

        <template #smart-bar-actions>
            <div class="price-drop-alert-list__actions">
                <sw-switch-field
                    v-model:value="showProductPrice"
                    :disabled="isSavingConfig"
                    bordered
                    label="Show product price"
                    @update:value="onTogglePriceVisibility"
                />
                <sw-button variant="secondary" @click="$router.push({ name: 'price.drop.alert.settings' })">
                    Channel Settings
                </sw-button>
            </div>
        </template>

        <template #content>
            <sw-entity-listing
                v-if="items"
                :items="items"
                :repository="repository"
                :show-selection="false"
                :columns="columns"
                :is-loading="isLoading"
                :full-page="false"
                :sort-by="sortBy"
                :sort-direction="sortDirection"
                :allow-column-edit="false"
                :allow-inline-edit="false"
                :allow-delete="false"
                :allow-edit="false"
                :page="page"
                :limit="limit"
                :total="total"
                @page-change="onPageChange"
                @column-sort="onColumnSort"
            />
        </template>
    </sw-page>
{% endblock %}
