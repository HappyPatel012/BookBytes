<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="PriceDropAlerts\Core\Content\PriceDropAlert\PriceDropAlertDefinition">
            <tag name="shopware.entity.definition" entity="bookbytes_price_drop_alert"/>
        </service>

        <service id="PriceDropAlerts\Service\PriceResolver">
            <argument type="service" id="product.repository"/>
        </service>

        <service id="PriceDropAlerts\Service\PriceDropMailService">
            <argument type="service" id="Shopware\Core\Content\Mail\Service\MailService"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="router"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="PriceDropAlerts\Storefront\Controller\PriceDropAlertController" public="true">
            <argument type="service" id="bookbytes_price_drop_alert.repository"/>
            <argument type="service" id="PriceDropAlerts\Service\PriceResolver"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="PriceDropAlerts\Subscriber\WishlistPageSubscriber">
            <argument type="service" id="bookbytes_price_drop_alert.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="PriceDropAlerts\Subscriber\ProductPriceWrittenSubscriber">
            <argument type="service" id="bookbytes_price_drop_alert.repository"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="PriceDropAlerts\Service\PriceDropMailService"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
