{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_content %}
    <div class="container-main">
        <div class="container py-4">
            <h1 class="mb-3">Student Courses</h1>

            {% if courses.total > 0 %}
                <p class="text-muted">Showing {{ courses.elements|length }} of {{ total }} courses.</p>

                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Instructor</th>
                                <th>Level</th>
                                <th>Start Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for course in courses %}
                                <tr>
                                    <td>{{ course.title }}</td>
                                    <td>{{ course.instructor }}</td>
                                    <td>{{ course.level }}</td>
                                    <td>
                                        {% if course.startDate %}
                                            {{ course.startDate|format_date(locale=app.request.locale) }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <nav aria-label="Student course pagination">
                    <ul class="pagination">
                        <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                            <a class="page-link" href="{{ path('frontend.student_course.index', { page: currentPage - 1 }) }}">Previous</a>
                        </li>

                        {% for pageNumber in 1..totalPages %}
                            <li class="page-item {{ pageNumber == currentPage ? 'active' }}">
                                <a class="page-link" href="{{ path('frontend.student_course.index', { page: pageNumber }) }}">{{ pageNumber }}</a>
                            </li>
                        {% endfor %}

                        <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                            <a class="page-link" href="{{ path('frontend.student_course.index', { page: currentPage + 1 }) }}">Next</a>
                        </li>
                    </ul>
                </nav>
            {% else %}
                <div class="alert alert-info mb-0">No courses available yet.</div>
            {% endif %}
        </div>
    </div>
{% endblock %}
