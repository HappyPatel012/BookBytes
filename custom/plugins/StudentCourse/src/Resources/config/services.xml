<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="StudentCourse\Core\Content\Course\CourseDefinition">
            <tag name="shopware.entity.definition" entity="student_course" />
        </service>

        <service id="StudentCourse\Storefront\Controller\StudentCourseController" public="true">
            <argument type="service" id="Shopware\Storefront\Page\GenericPageLoaderInterface" />
            <argument type="service" id="student_course.repository" />
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
        </service>
    </services>
</container>
