{% block sw_promotion_v2_list_smart_bar_actions_add %}
    {% parent %}
    <mt-button
            @click="sendGlobalPromotionToExport()"
            variant="primary"
    >
        {{ $tc('klaviyo_integration_plugin.promotion.exportInKlaviyoFormatButtonLabel') }}
    </mt-button>
{% endblock %}

{% block sw_promotion_v2_list_grid_columns_actions %}
    {% parent %}
    {% block sw_promotion_v2_list_grid_columns_actions_klaviyo_export %}
        <template #klaviyo-more-actions="{ item }">
            <sw-context-menu-item
                    :disabled="(item && item.orderCount > 0)"
                    @click="sendPromotionToExport(item.id)"
            >
                {{ $tc('klaviyo_integration_plugin.promotion.exportInKlaviyoFormatButtonLabel') }}
            </sw-context-menu-item>
        </template>
    {% endblock %}
{% endblock %}

{% parent %}
