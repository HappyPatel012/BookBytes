{% block klaviyo_integration_settings_order %}
    <mt-card :title="$tc('klaviyo-integration-settings.order.title')">

        {% block klaviyo_integration_settings_order_custom_field_mapping %}
            <template v-if="!isLoading" v-for="mappedField, mappedKey in allConfigs['null'][configPath]">
                <sw-container columns="2fr 5fr 5fr" gap="16px">
                    <mt-switch
                            :label="$tc('sw-boolean-filter.active')"
                            :disabled="isLoading"
                            v-model="mappedField.active">
                    </mt-switch>

                    <mt-text-field
                            v-model="mappedField.customLabel"
                            :disabled="!mappedField.active"
                            :placeholder="$tc('klaviyo-integration-settings.order.fieldMapping.item.fieldNamePlaceholder')"
                            :error="mappingErrorStates[mappedKey]?.code !== undefined ? mappingErrorStates[mappedKey] : null"
                            :label="$tc('klaviyo-integration-settings.order.fieldMapping.item.fieldName')">
                    </mt-text-field>
                    <div class="custom-field-hint-container">
                        <span>{{ getCustomFieldHint(mappedKey) }}</span>
                    </div>
                </sw-container>
            </template>

            <div v-if="!isLoading && noCustomFieldsError" class="klaviyo-fieldmapping-notice-block">
                {{ $tc(noCustomFieldsError) }}
            </div>
        {% endblock %}
        <mt-loader v-if="isLoading"/>
    </mt-card>
{% endblock %}