            {% block klaviyo_integration_settings_general_daily_synchronization_time %}
                <sw-inherit-wrapper v-if="selectedSalesChannelId === null && actualConfigData['klavi_overd.config.dailySynchronization']"
                                    v-model:value="actualConfigData['klavi_overd.config.dailySynchronizationTime']"
                                    :inheritedValue="selectedSalesChannelId === null ? null : allConfigs['null']['klavi_overd.config.dailySynchronizationTime']">
                    <template #content="props">
                        <mt-datepicker
                                :map-inheritance="props"
                                v-model:value="props.currentValue"
                                dateType="time"
                                dateFormat="H:i"
                                :time="true"
                                :disabled="props.isInherited"
                                :label="$tc('klaviyo-integration-settings.configs.timeDailySynchronization.label')"
                                :help-text="$tc('klaviyo-integration-settings.configs.timeDailySynchronization.helpText')"
                                @update:model-value="props.updateCurrentValue">
                        </mt-datepicker>
                    </template>
                </sw-inherit-wrapper>
            {% endblock %}

            {% block klaviyo_integration_settings_general_old_job_cleanup_flag %}
                <div class="boolean-config-container">
                    <sw-inherit-wrapper v-if="selectedSalesChannelId === null"
                                        v-model:value="actualConfigData['klavi_overd.config.oldJobCleanup']"
                                        :label="$tc('klaviyo-integration-settings.configs.oldJobCleanup.label')"
                                        :help-text="$tc('klaviyo-integration-settings.configs.oldJobCleanup.helpText')"
                                        :inheritedValue="selectedSalesChannelId === null ? null : allConfigs['null']['klavi_overd.config.oldJobCleanup']">
                        <template #content="props">
                            <mt-switch
                                :map-inheritance="props"
                                :disabled="props.isInherited"
                                v-model="props.currentValue"
                                @update:model-value="props.updateCurrentValue">
                            </mt-switch>
                        </template>
                    </sw-inherit-wrapper>
                </div>
            {% endblock %}

            {% block klaviyo_integration_settings_general_old_job_cleanup_period %}
                <sw-inherit-wrapper v-if="selectedSalesChannelId === null && actualConfigData['klavi_overd.config.oldJobCleanup']"
                                    v-model:value="actualConfigData['klavi_overd.config.oldJobCleanupPeriod']"
                                    :inheritedValue="selectedSalesChannelId === null ? null : allConfigs['null']['klavi_overd.config.oldJobCleanupPeriod']">
                    <template #content="props">
                        <sw-single-select name="klavi_overd.config.oldJobCleanupPeriod"
                                          labelProperty="label"
                                          valueProperty="value"
                                          :options="createOldJobCleanupPeriodOptions"
                                          :isInherited="props.isInherited"
                                          :disabled="props.isInherited"
                                          show-clearable-button
                                          v-model:value="props.currentValue"
                                          @update:value="props.updateCurrentValue">
                        </sw-single-select>
                    </template>
                </sw-inherit-wrapper>
            {% endblock %}
