{% block klaviyo_integration_settings_general %}
    <div>
        <mt-card :title="$tc('klaviyo-integration-settings.general.initialization.general-label')"
                 class="klaviyo-interaction-settings">
            <sw-inherit-wrapper
                class="cookie-consent-inheritance"
                v-model:value="actualConfigData['klavi_overd.config.cookieConsent']"
                :inheritedValue="selectedSalesChannelId === null ? null : allConfigs['null']['klavi_overd.config.cookieConsent']"
                :label="$tc('klaviyo-integration-settings.configs.cookieConsent.label')"
                :help-text="$tc('klaviyo-integration-settings.configs.cookieConsent.helpText')">
                <template #content="props">
                    <sw-single-select name="klavi_overd.config.cookieConsent"
                                      labelProperty="label"
                                      valueProperty="value"
                                      :options="createCookieConsentOptions"
                                      :isInherited="props.isInherited"
                                      :disabled="props.isInherited"
                                      show-clearable-button
                                      v-model:value="props.currentValue"
                                      @update:value="props.updateCurrentValue">
                    </sw-single-select>
                </template>
            </sw-inherit-wrapper>
            
            <div class="boolean-config-container">
                <sw-inherit-wrapper
                        v-model:value="actualConfigData['klavi_overd.config.isInitializeKlaviyoAfterInteraction']"
                        :label="$tc('klaviyo-integration-settings.general.initialization.label')"
                        :helpText="$tc('klaviyo-integration-settings.general.initialization.helpText')"
                        :inheritedValue="selectedSalesChannelId === null ? null : allConfigs['null']['klavi_overd.config.isInitializeKlaviyoAfterInteraction']"
                        :customInheritationCheckFunction="checkBoolFieldInheritance">
                    <template #content="props">
                        <mt-switch name="klavi_overd.config.isInitializeKlaviyoAfterInteraction"
                                         :mapInheritance="props"
                                         :disabled="props.isInherited"
                                         v-model="props.currentValue"
                                         @update:model-value="props.updateCurrentValue">
                        </mt-switch>
                    </template>
                </sw-inherit-wrapper>
            </div>
        </mt-card>
        <mt-card :title="$tc('klaviyo-integration-settings.general.title')">
            {% block klaviyo_integration_settings_general_credentials_alert %}
                <sw-alert v-if="selectedSalesChannelId === null" variant="warning">
                    {{ $t('klaviyo-integration-settings.general.credentialsAlert') }}
                </sw-alert>
            {% endblock %}

            {% block klaviyo_integration_settings_general_test_api %}
                <sw-button-process variant="primary" ghost v-if="selectedSalesChannelId !== null"
                                   :isLoading="apiValidationInProgress"
                                   @click="validateApiCredentials">
                    {{ $tc('klaviyo-integration-settings.configs.apiValidation.buttonLabel') }}
                </sw-button-process>
            {% endblock %}

            {% block klaviyo_integration_settings_general_enabled %}
                <mt-switch
                        v-if="selectedSalesChannelId !== null"
                        class="no-top-margin"
                        v-model="actualConfigData['klavi_overd.config.enabled']"
                        name="klavi_overd.config.enabled"
                        :label="$tc('klaviyo-integration-settings.configs.enabled.label')"
                        :helpText="$tc('klaviyo-integration-settings.configs.enabled.helpText')">
                </mt-switch>
            {% endblock %}

            {% block klaviyo_integration_settings_general_private_api_key %}
                <mt-password-field
                        v-model="actualConfigData['klavi_overd.config.privateApiKey']"
                        name="klavi_overd.config.privateApiKey"
                        :label="$tc('klaviyo-integration-settings.configs.privateApiKey.label')"
                        :helpText="$tc('klaviyo-integration-settings.configs.privateApiKey.helpText')"
                        :disabled="selectedSalesChannelId === null"
                        :error="privateKeyErrorState"
                        required>
                </mt-password-field>
            {% endblock %}

            {% block klaviyo_integration_settings_general_public_api_key %}
                <mt-text-field
                        v-model="actualConfigData['klavi_overd.config.publicApiKey']"
                        name="klavi_overd.config.publicApiKey"
                        :label="$tc('klaviyo-integration-settings.configs.publicApiKey.label')"
                        :helpText="$tc('klaviyo-integration-settings.configs.publicApiKey.helpText')"
                        :disabled="selectedSalesChannelId === null"
                        :error="publicKeyErrorState"
                        required>
                </mt-text-field>
            {% endblock %}

            {% block klaviyo_integration_settings_general_double_opt_in_alert %}
                <sw-alert variant="warning">
                    {{ $t('klaviyo-integration-settings.general.doubleoptinAlert') }}
                </sw-alert>
            {% endblock %}

            {% block klaviyo_integration_settings_general_klaviyo_list_for_subscribers_sync %}
                <sw-single-select name="klavi_overd.config.klaviyoListForSubscribersSync"
                                  v-model:value="actualConfigData['klavi_overd.config.klaviyoListForSubscribersSync']"
                                  ref="newsletterListId"
                                  :label="$tc('klaviyo-integration-settings.configs.klaviyoListForSubscribersSync.label')"
                                  :helpText="$tc('klaviyo-integration-settings.configs.klaviyoListForSubscribersSync.helpText')"
                                  :error="listIdErrorState"
                                  :options="createListsOptions"
                                  :disabled="(selectedSalesChannelId === null) || areListsLoading"
                                  :isLoading="(selectedSalesChannelId !== null) && areListsLoading"
                                  required>
                </sw-single-select>
            {% endblock %}

            {% block klaviyo_integration_settings_general_varian_for_bis %}
