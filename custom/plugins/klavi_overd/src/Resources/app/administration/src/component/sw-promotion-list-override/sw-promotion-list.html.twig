{% block sw_promotion_list_smart_bar_actions_add %}
    {% parent %}
    <mt-button
            v-tooltip="{
                message: $tc('sw-privileges.tooltip.warning'),
                disabled: acl.can('promotion.viewer'),
                showOnDisabledElements: true,
                position: 'bottom'
            }"
            @click="this.$router.push('api.klaviyo.integration.promotion.export')"
            :disabled="!acl.can('promotion.creator')"
            variant="primary"
    >
        {{ $tc('klaviyo_integration_plugin.promotion.exportInKlaviyoFormatButtonLabel') }}
    </mt-button>
{% endblock %}

{% parent %}