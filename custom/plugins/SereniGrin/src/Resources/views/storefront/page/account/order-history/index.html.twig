{% sw_extends '@Storefront/storefront/page/account/order-history/index.html.twig' %}

{% block page_account_orders %}
    <div class="bb-account-orders">
        <section class="bb-orders-hero">
            <div class="bb-orders-hero-text">
                <div class="bb-orders-kicker">{{ 'account.myAccount'|trans|sw_sanitize }}</div>
                <h1 class="bb-orders-title">{{ 'account.ordersTitle'|trans|sw_sanitize }}</h1>
                <p class="bb-orders-subtitle">{{ 'account.ordersWelcome'|trans|sw_sanitize }}</p>
            </div>
            <div class="bb-orders-hero-actions">
                <a class="btn bb-ghost" href="{{ path('frontend.account.home.page') }}">{{ 'account.overviewTitle'|trans|sw_sanitize }}</a>
                <a class="btn bb-ghost" href="{{ path('frontend.account.profile.page') }}">{{ 'account.profileLink'|trans|sw_sanitize }}</a>
                <a class="btn bb-ghost" href="{{ path('frontend.account.address.page') }}">{{ 'account.addressLink'|trans|sw_sanitize }}</a>
            </div>
        </section>

        {{ parent() }}
    </div>
{% endblock %}
