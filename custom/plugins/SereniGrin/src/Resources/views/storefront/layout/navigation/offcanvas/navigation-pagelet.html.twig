<div class="bb-mobile-pagelet">
    {% sw_include '@Storefront/storefront/layout/navigation/offcanvas/categories.html.twig' with { navigation: page.navigation } %}

    {% set accountLink = context.customer ? path('frontend.account.home.page') : path('frontend.account.login.page') %}

    <footer class="bb-mobile-pagelet-footer">
        <nav class="bb-mobile-footer-actions" aria-label="Mobile quick actions">
            <a class="bb-mobile-footer-link"
               href="{{ accountLink }}"
               title="{{ 'account.myAccount'|trans|striptags }}"
               aria-label="{{ 'account.myAccount'|trans|striptags }}">
                {% sw_icon 'avatar' %}
            </a>

            {% if config('core.cart.wishlistEnabled') %}
                <a class="bb-mobile-footer-link"
                   href="{{ path('frontend.wishlist.page') }}"
                   title="{{ 'header.wishlist'|trans|striptags }}"
                   aria-label="{{ 'header.wishlist'|trans|striptags }}">
                    {% sw_icon 'heart' %}
                </a>
            {% endif %}

            <a class="bb-mobile-footer-link"
               href="{{ path('frontend.checkout.cart.page') }}"
               title="{{ 'checkout.cartTitle'|trans|striptags }}"
               aria-label="{{ 'checkout.cartTitle'|trans|striptags }}">
                {% sw_icon 'bag' %}
            </a>
        </nav>
    </footer>
</div>
