{% set categories = page.header.navigation.tree|default([]) %}

<div class="ccsf-slider js-ccsf-slider"
     data-ccsf-slider='{"items": 5, "slideBy": 1, "gutter": 14}'>
    <div class="ccsf-head">
        <h3 class="ccsf-title">Browse Categories</h3>
        <div class="ccsf-controls" aria-label="Category slider controls">
            <button type="button" class="ccsf-control ccsf-prev" aria-label="Previous categories">
                <span aria-hidden="true">&#10094;</span>
            </button>
            <button type="button" class="ccsf-control ccsf-next" aria-label="Next categories">
                <span aria-hidden="true">&#10095;</span>
            </button>
        </div>
    </div>

    {% if categories|length > 0 %}
        <div class="ccsf-track">
            {% for item in categories %}
                {% set category = item.category %}
                {% if category %}
                    <article class="ccsf-card">
                        <a class="ccsf-link"
                           href="{{ path('frontend.navigation.page', { navigationId: category.id }) }}">
                            <span class="ccsf-name">{{ category.translated.name }}</span>
                        </a>
                    </article>
                {% endif %}
            {% endfor %}
        </div>
    {% else %}
        <p class="ccsf-empty">No categories available.</p>
    {% endif %}
</div>
